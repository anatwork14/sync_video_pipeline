# ── VideoSync Pipeline Configuration ──────────────────────────────────────────

# Database and Cache
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/videosync
REDIS_URL=redis://redis:6379/0

# Storage
STORAGE_BASE=./storage

# Security
SECRET_KEY=generate_your_own_secret_key_here

# Frontend/CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:80"]

# Optional: Cloudflare Tunnel (if using run_tunnel.py)
# TUNNEL_URL=
